<!-- Greeting -->
<p style="font-size: 15px; color: #050822; margin: 0 0 8px 0; font-weight: 600;">
  Bonjour {{name}},
</p>

<p style="font-size: 15px; color: #495057; margin: 0 0 30px 0; line-height: 1.6;">
  Nous vous confirmons la bonne réception de votre paiement pour le service <strong style="color: #050822;">{{serviceName}}</strong>.
</p>

<!-- Status Badge -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 0 0 30px 0;">
    <tr>
        <td style="text-align: center; padding: 20px; background-color: #d1f4e0; border-left: 4px solid #28a745;">
            <p style="margin: 0; color: #155724; font-size: 14px; font-weight: 600;">
                ✓ PAIEMENT CONFIRMÉ
            </p>
        </td>
    </tr>
</table>

<!-- Booking Details -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f8f9fa; padding: 0; margin: 0 0 25px 0; border: 1px solid #e9ecef;">
    <tr>
        <td style="padding: 25px 30px; border-bottom: 1px solid #e9ecef;">
            <h2 style="color: #050822; font-size: 16px; margin: 0; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
                Détails de votre réservation
            </h2>
        </td>
    </tr>
    <tr>
        <td style="padding: 0;">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                <tr style="border-bottom: 1px solid #e9ecef;">
                    <td style="padding: 18px 30px; color: #6c757d; font-size: 14px; font-weight: 500; width: 35%;">Consultant</td>
                    <td style="padding: 18px 30px; color: #212529; font-size: 14px; font-weight: 500;">{{consultant}}</td>
                </tr>
                <tr style="border-bottom: 1px solid #e9ecef;">
                    <td style="padding: 18px 30px; color: #6c757d; font-size: 14px; font-weight: 500;">Date</td>
                    <td style="padding: 18px 30px; color: #212529; font-size: 14px; font-weight: 500;">{{date}}</td>
                </tr>
                <tr style="border-bottom: 1px solid #e9ecef;">
                    <td style="padding: 18px 30px; color: #6c757d; font-size: 14px; font-weight: 500;">Horaire</td>
                    <td style="padding: 18px 30px; color: #212529; font-size: 14px; font-weight: 500;">{{time}}</td>
                </tr>
                {{#if frequency}}
                <tr style="border-bottom: 1px solid #e9ecef;">
                    <td style="padding: 18px 30px; color: #6c757d; font-size: 14px; font-weight: 500;">Fréquence</td>
                    <td style="padding: 18px 30px; color: #212529; font-size: 14px; font-weight: 500;">{{frequency}}</td>
                </tr>
                {{/if}}
                <tr style="background-color: #ffffff;">
                    <td style="padding: 18px 30px; color: #6c757d; font-size: 14px; font-weight: 600;">Montant payé</td>
                    <td style="padding: 18px 30px; color: #28a745; font-size: 16px; font-weight: 700;">{{amount}} €</td>
                </tr>
            </table>
        </td>
    </tr>
</table>

<!-- Pending Validation Notice -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 0 0 25px 0;">
    <tr>
        <td style="background-color: #fff3cd; padding: 20px 25px; border-left: 4px solid #ffc107;">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                <tr>
                    <td style="width: 30px; vertical-align: top; padding-right: 15px;">
                        <span style="font-size: 20px;">⏳</span>
                    </td>
                    <td>
                        <p style="margin: 0 0 5px 0; color: #856404; font-size: 14px; font-weight: 600;">
                            En attente de validation
                        </p>
                        <p style="margin: 0; color: #856404; font-size: 13px; line-height: 1.5;">
                            Votre réservation sera confirmée dès que le consultant aura validé votre demande. Vous recevrez un email avec le lien de connexion à la session.
                        </p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>

<!-- Next Steps -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 0 0 30px 0;">
    <tr>
        <td style="padding: 0 0 15px 0;">
            <h3 style="color: #050822; font-size: 15px; margin: 0; font-weight: 600;">
                Prochaines étapes
            </h3>
        </td>
    </tr>
    <tr>
        <td>
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                <tr>
                    <td style="padding: 10px 0; vertical-align: top; width: 30px;">
                        <span style="display: inline-block; width: 24px; height: 24px; background-color: #192bc2; color: #ffffff; text-align: center; line-height: 24px; border-radius: 50%; font-size: 12px; font-weight: 600;">1</span>
                    </td>
                    <td style="padding: 10px 0 10px 10px; color: #495057; font-size: 14px; line-height: 1.5;">
                        Le consultant validera votre réservation
                    </td>
                </tr>
                <tr>
                    <td style="padding: 10px 0; vertical-align: top;">
                        <span style="display: inline-block; width: 24px; height: 24px; background-color: #192bc2; color: #ffffff; text-align: center; line-height: 24px; border-radius: 50%; font-size: 12px; font-weight: 600;">2</span>
                    </td>
                    <td style="padding: 10px 0 10px 10px; color: #495057; font-size: 14px; line-height: 1.5;">
                        Vous recevrez un email avec le lien de visioconférence
                    </td>
                </tr>
                <tr>
                    <td style="padding: 10px 0; vertical-align: top;">
                        <span style="display: inline-block; width: 24px; height: 24px; background-color: #192bc2; color: #ffffff; text-align: center; line-height: 24px; border-radius: 50%; font-size: 12px; font-weight: 600;">3</span>
                    </td>
                    <td style="padding: 10px 0 10px 10px; color: #495057; font-size: 14px; line-height: 1.5;">
                        Préparez vos questions et objectifs pour la session
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>

<!-- Divider -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 30px 0;">
    <tr>
        <td style="border-top: 1px solid #dee2e6;"></td>
    </tr>
</table>

<!-- Support Message -->
<p style="font-size: 13px; color: #6c757d; margin: 0 0 5px 0; line-height: 1.5;">
  Pour toute question, notre équipe reste à votre disposition.
</p>

<!-- Signature -->
<p style="font-size: 14px; color: #495057; margin: 0; line-height: 1.5;">
  Cordialement,<br>
  <strong style="color: #050822;">L'équipe Talenteed</strong>
</p>
