<!-- Bouton CTA réutilisable -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin: {{margin}};">
    <tr>
        <td style="background-color: #192bc2; text-align: center; border-radius: 4px;">
            <a href="{{url}}" target="_blank" style="background-color: #192bc2; border: none; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 14px; font-weight: 600; line-height: 1.5; text-align: center; text-decoration: none; display: inline-block; border-radius: 4px; padding: 14px 35px; color: #ffffff; text-transform: uppercase; letter-spacing: 0.5px; transition: all 0.3s ease;">
                {{text}}
            </a>
        </td>
    </tr>
</table>
