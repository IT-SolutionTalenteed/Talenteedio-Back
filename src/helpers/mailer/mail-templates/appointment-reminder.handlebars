<!-- Greeting -->
<p style="font-size: 15px; color: #050822; margin: 0 0 8px 0; font-weight: 600;">
  Bonjour {{name}},
</p>

<p style="font-size: 15px; color: #495057; margin: 0 0 30px 0; line-height: 1.6;">
  Nous vous rappelons que votre session de coaching est prévue {{timeUntil}}.
</p>

<!-- Alert Badge -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 0 0 30px 0;">
    <tr>
        <td style="text-align: center; padding: 20px; background-color: #fff3cd; border-left: 4px solid #ffc107;">
            <p style="margin: 0; color: #856404; font-size: 14px; font-weight: 600;">
                ⏰ RAPPEL DE RENDEZ-VOUS
            </p>
        </td>
    </tr>
</table>

<!-- Appointment Details -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f8f9fa; padding: 0; margin: 0 0 25px 0; border: 1px solid #e9ecef;">
    <tr>
        <td style="padding: 25px 30px; border-bottom: 1px solid #e9ecef;">
            <h2 style="color: #050822; font-size: 16px; margin: 0; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
                Détails du rendez-vous
            </h2>
        </td>
    </tr>
    <tr>
        <td style="padding: 0;">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                <tr style="border-bottom: 1px solid #e9ecef;">
                    <td style="padding: 18px 30px; color: #6c757d; font-size: 14px; font-weight: 500; width: 35%;">Consultant</td>
                    <td style="padding: 18px 30px; color: #212529; font-size: 14px; font-weight: 500;">{{consultant}}</td>
                </tr>
                <tr style="border-bottom: 1px solid #e9ecef;">
                    <td style="padding: 18px 30px; color: #6c757d; font-size: 14px; font-weight: 500;">Service</td>
                    <td style="padding: 18px 30px; color: #212529; font-size: 14px; font-weight: 500;">{{serviceName}}</td>
                </tr>
                <tr style="border-bottom: 1px solid #e9ecef; background-color: #fffbf0;">
                    <td style="padding: 18px 30px; color: #6c757d; font-size: 14px; font-weight: 600;">Date</td>
                    <td style="padding: 18px 30px; color: #212529; font-size: 14px; font-weight: 700;">{{date}}</td>
                </tr>
                <tr style="border-bottom: 1px solid #e9ecef; background-color: #fffbf0;">
                    <td style="padding: 18px 30px; color: #6c757d; font-size: 14px; font-weight: 600;">Horaire</td>
                    <td style="padding: 18px 30px; color: #212529; font-size: 14px; font-weight: 700;">{{time}}</td>
                </tr>
            </table>
        </td>
    </tr>
    {{#if meetingLink}}
    <tr>
        <td style="padding: 25px 30px; background-color: #ffffff; text-align: center;">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin: 0 auto;">
                <tr>
                    <td style="background-color: #192bc2; border-radius: 4px;">
                        <a href="{{meetingLink}}" target="_blank" style="background-color: #192bc2; border: none; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 14px; font-weight: 600; line-height: 1.5; text-align: center; text-decoration: none; display: inline-block; border-radius: 4px; padding: 14px 35px; color: #ffffff; text-transform: uppercase; letter-spacing: 0.5px;">
                            REJOINDRE LA SESSION
                        </a>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
    {{/if}}
</table>

<!-- Checklist -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 0 0 25px 0;">
    <tr>
        <td style="padding: 0 0 15px 0;">
            <h3 style="color: #050822; font-size: 15px; margin: 0; font-weight: 600;">
                Checklist avant la session
            </h3>
        </td>
    </tr>
    <tr>
        <td>
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                <tr>
                    <td style="padding: 10px 0; vertical-align: top; width: 30px;">
                        <span style="color: #28a745; font-size: 16px;">✓</span>
                    </td>
                    <td style="padding: 10px 0 10px 10px; color: #495057; font-size: 14px; line-height: 1.5;">
                        Vérifier votre connexion internet
                    </td>
                </tr>
                <tr>
                    <td style="padding: 10px 0; vertical-align: top;">
                        <span style="color: #28a745; font-size: 16px;">✓</span>
                    </td>
                    <td style="padding: 10px 0 10px 10px; color: #495057; font-size: 14px; line-height: 1.5;">
                        Tester votre caméra et microphone
                    </td>
                </tr>
                <tr>
                    <td style="padding: 10px 0; vertical-align: top;">
                        <span style="color: #28a745; font-size: 16px;">✓</span>
                    </td>
                    <td style="padding: 10px 0 10px 10px; color: #495057; font-size: 14px; line-height: 1.5;">
                        Préparer vos questions
                    </td>
                </tr>
                <tr>
                    <td style="padding: 10px 0; vertical-align: top;">
                        <span style="color: #28a745; font-size: 16px;">✓</span>
                    </td>
                    <td style="padding: 10px 0 10px 10px; color: #495057; font-size: 14px; line-height: 1.5;">
                        Trouver un environnement calme
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>

<!-- Tip -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 0 0 30px 0;">
    <tr>
        <td style="background-color: #e7f3ff; padding: 18px 25px; border-left: 4px solid #0066cc;">
            <p style="margin: 0; color: #004085; font-size: 13px; line-height: 1.5;">
                <strong>Conseil :</strong> Connectez-vous 5 minutes avant l'heure prévue pour vous assurer que tout fonctionne correctement.
            </p>
        </td>
    </tr>
</table>

<!-- Divider -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 30px 0;">
    <tr>
        <td style="border-top: 1px solid #dee2e6;"></td>
    </tr>
</table>

<!-- Support Message -->
<p style="font-size: 13px; color: #6c757d; margin: 0 0 5px 0; line-height: 1.5;">
  Besoin de reporter ou d'annuler ? Contactez-nous au plus vite.
</p>

<!-- Signature -->
<p style="font-size: 14px; color: #495057; margin: 0; line-height: 1.5;">
  À très bientôt,<br>
  <strong style="color: #050822;">L'équipe Talenteed</strong>
</p>
